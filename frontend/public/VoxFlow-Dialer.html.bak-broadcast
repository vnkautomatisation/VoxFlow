<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>VoxFlow Dialer</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        :root {
            --ink: #111118;
            --ink2: #18181f;
            --ink3: #1f1f2a;
            --ink4: #27273a;
            --ink5: #30304a;
            --line: #2e2e44;
            --line2: #3a3a55;
            --violet: #7b61ff;
            --vi2: #6145ff;
            --vi3: rgba(123,97,255,.13);
            --vi4: rgba(123,97,255,.06);
            --mint: #00d4aa;
            --mi2: #00a884;
            --mi3: rgba(0,212,170,.12);
            --rose: #ff4d6d;
            --ro2: #e03050;
            --ro3: rgba(255,77,109,.12);
            --sky: #38b6ff;
            --sk3: rgba(56,182,255,.12);
            --amber: #ffb547;
            --am3: rgba(255,181,71,.12);
            --txt: #eeeef8;
            --tx2: #9898b8;
            --tx3: #55557a;
            --tx4: #35355a;
            --font: 'DM Sans',sans-serif;
            --mono: 'JetBrains Mono',monospace;
            --rb: 14px;
            --rs: 8px;
            --rp: 20px;
        }

        html, body {
            min-height: 100vh;
            background: var(--ink);
            font-family: var(--font);
            color: var(--txt);
            display: flex;
            align-items: flex-end;
            justify-content: flex-end;
            padding: 16px
        }

        .popup {
            width: 360px;
            height: 700px;
            background: var(--ink2);
            border-radius: 20px;
            border: 1px solid var(--line);
            box-shadow: 0 0 0 1px rgba(123,97,255,.08),0 40px 100px rgba(0,0,0,.9),0 12px 40px rgba(0,0,0,.7),inset 0 1px 0 rgba(255,255,255,.05);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative
        }
        /* ── TOAST ─────────────────────────────────────────────── */
        .toast {
            position: absolute;
            top: 12px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--ink4);
            border: 1px solid var(--line2);
            border-radius: var(--rp);
            padding: 6px 16px;
            font-size: 11.5px;
            font-weight: 600;
            color: var(--txt);
            box-shadow: 0 8px 28px rgba(0,0,0,.6);
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s;
            z-index: 999;
            white-space: nowrap
        }

            .toast.on {
                opacity: 1
            }
        /* ── ROLE BADGE ─────────────────────────────────────────── */
        .role-badge {
            padding: 2px 8px;
            border-radius: var(--rp);
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .07em
        }

            .role-badge.admin {
                background: rgba(123,97,255,.2);
                border: 1px solid rgba(123,97,255,.35);
                color: var(--violet)
            }

            .role-badge.agent {
                background: rgba(56,182,255,.15);
                border: 1px solid rgba(56,182,255,.25);
                color: var(--sky)
            }
        /* ── HEADER ─────────────────────────────────────────────── */
        .hdr {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 11px 14px;
            background: var(--ink3);
            border-bottom: 1px solid var(--line);
            flex-shrink: 0
        }

        .logo {
            font-weight: 700;
            font-size: 14px;
            color: var(--violet);
            letter-spacing: -.2px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 6px
        }

        .logo-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--violet);
            box-shadow: 0 0 8px var(--violet)
        }

        .hdr-mid {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px
        }

        .chip {
            display: flex;
            align-items: center;
            gap: 5px;
            background: var(--ink4);
            border: 1px solid var(--line);
            border-radius: var(--rp);
            padding: 3px 9px 3px 7px;
            font-size: 10.5px;
            font-weight: 600;
            color: var(--tx2);
            cursor: pointer
        }

        .chip-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
            transition: all .3s
        }

            .chip-dot.on {
                background: var(--mint);
                box-shadow: 0 0 6px var(--mint)
            }

            .chip-dot.pause {
                background: var(--amber);
                box-shadow: 0 0 6px var(--amber)
            }

            .chip-dot.off {
                background: var(--tx3);
                box-shadow: none
            }

        .ext-chip {
            display: flex;
            align-items: center;
            gap: 5px;
            background: rgba(56,182,255,.08);
            border: 1px solid rgba(56,182,255,.2);
            border-radius: var(--rp);
            padding: 3px 9px;
            font-size: 10.5px;
            font-weight: 700;
            color: var(--sky);
            font-family: var(--mono)
        }

        .hdr-r {
            display: flex;
            align-items: center;
            gap: 5px;
            flex-shrink: 0
        }

        .ibt {
            width: 28px;
            height: 28px;
            background: none;
            border: none;
            color: var(--tx3);
            cursor: pointer;
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s
        }

            .ibt:hover {
                background: var(--ink4);
                color: var(--txt)
            }

        .ssel {
            background: none;
            border: none;
            color: var(--txt);
            font-size: 10.5px;
            font-family: var(--font);
            font-weight: 600;
            cursor: pointer;
            outline: none;
            -webkit-appearance: none
        }

            .ssel option {
                background: #1f1f2a
            }
        /* ── TABS ─────────────────────────────────────────────────── */
        .tabs {
            display: flex;
            background: var(--ink3);
            border-bottom: 1px solid var(--line);
            flex-shrink: 0;
            overflow-x: auto;
            scrollbar-width: none
        }

            .tabs::-webkit-scrollbar {
                display: none
            }

        .tab {
            flex: 1;
            min-width: 0;
            border: none;
            border-bottom: 2px solid transparent;
            background: none;
            color: var(--tx3);
            font-size: 9px;
            font-family: var(--font);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            padding: 9px 2px 7px;
            cursor: pointer;
            position: relative;
            transition: all .15s;
            white-space: nowrap
        }

            .tab.on {
                color: var(--txt);
                border-bottom-color: var(--violet);
                background: rgba(123,97,255,.04)
            }

            .tab:hover:not(.on) {
                color: var(--tx2)
            }

        .tbdg {
            position: absolute;
            top: 4px;
            right: 2px;
            background: var(--rose);
            color: #fff;
            font-size: 8px;
            font-weight: 800;
            border-radius: 50%;
            width: 13px;
            height: 13px;
            display: flex;
            align-items: center;
            justify-content: center
        }
        /* ── SCROLL ─────────────────────────────────────────────── */
        .scroll {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden
        }

            .scroll::-webkit-scrollbar {
                width: 3px
            }

            .scroll::-webkit-scrollbar-thumb {
                background: var(--line2);
                border-radius: 2px
            }
        /* ── VIEW / PANE ────────────────────────────────────────── */
        .view {
            display: none
        }

            .view.on {
                display: flex;
                flex-direction: column
            }

        .pane {
            display: none
        }

            .pane.on {
                display: block
            }

        .p12 {
            padding: 12px
        }

        .slbl {
            font-size: 9px;
            color: var(--tx3);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .1em;
            margin-bottom: 9px;
            display: flex;
            align-items: center;
            gap: 7px
        }

            .slbl::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--line)
            }
        /* ── LOGIN ─────────────────────────────────────────────── */
        .login-wrap {
            padding: 28px 22px;
            display: flex;
            flex-direction: column
        }

        .lbrand {
            text-align: center;
            margin-bottom: 26px
        }

            .lbrand .nm {
                font-size: 30px;
                font-weight: 700;
                letter-spacing: -.5px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0
            }

            .lbrand .sb {
                font-size: 11px;
                color: var(--tx3);
                margin-top: 4px
            }

        .field {
            margin-bottom: 13px
        }

            .field label {
                display: block;
                font-size: 10px;
                color: var(--tx3);
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .07em;
                margin-bottom: 5px
            }

            .field input {
                width: 100%;
                background: var(--ink3);
                border: 1px solid var(--line);
                border-radius: var(--rs);
                padding: 9px 12px;
                color: var(--txt);
                font-size: 13px;
                font-family: var(--font);
                outline: none;
                transition: border-color .15s
            }

                .field input:focus {
                    border-color: var(--violet)
                }

        .btn-login {
            width: 100%;
            margin-top: 6px;
            background: var(--violet);
            border: none;
            color: #fff;
            padding: 12px;
            border-radius: var(--rb);
            font-size: 14px;
            font-weight: 700;
            font-family: var(--font);
            cursor: pointer;
            transition: background .15s
        }

            .btn-login:hover {
                background: var(--vi2)
            }

        .lerr {
            display: none;
            background: var(--ro3);
            border: 1px solid rgba(255,77,109,.3);
            border-radius: var(--rs);
            padding: 8px 12px;
            font-size: 11px;
            color: var(--rose);
            margin-bottom: 12px;
            font-weight: 600
        }
        /* ── DIALER ─────────────────────────────────────────────── */
        .dinput {
            width: 100%;
            background: var(--ink3);
            border: 1px solid var(--line);
            border-radius: var(--rb);
            color: var(--txt);
            font-family: var(--mono);
            font-size: 22px;
            text-align: center;
            letter-spacing: 4px;
            padding: 12px 14px 11px;
            outline: none;
            transition: border-color .15s;
            margin-bottom: 10px
        }

            .dinput:focus {
                border-color: var(--violet)
            }

            .dinput::placeholder {
                color: var(--tx4);
                letter-spacing: 0;
                font-size: 13px;
                font-family: var(--font)
            }

        .kpad {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 1px;
            background: var(--line);
            border-radius: var(--rb);
            overflow: hidden;
            margin-bottom: 10px
        }

        .key {
            background: var(--ink3);
            border: none;
            color: var(--txt);
            padding: 12px 4px;
            font-size: 17px;
            font-family: var(--font);
            font-weight: 600;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1px;
            transition: background .1s
        }

            .key:hover {
                background: var(--ink4)
            }

            .key:active {
                background: var(--ink5)
            }

        .ksub {
            font-size: 8px;
            color: var(--tx3);
            letter-spacing: .12em;
            font-weight: 600
        }

        .key.sp {
            color: var(--violet)
        }

        .btn-call {
            width: 100%;
            background: linear-gradient(135deg,var(--mint),var(--mi2));
            border: none;
            color: #001a14;
            padding: 12px;
            border-radius: var(--rb);
            font-size: 13px;
            font-weight: 700;
            font-family: var(--font);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all .15s;
            box-shadow: 0 4px 22px rgba(0,212,170,.25)
        }

            .btn-call:hover {
                box-shadow: 0 6px 28px rgba(0,212,170,.4);
                transform: translateY(-1px)
            }

            .btn-call:disabled {
                background: var(--ink4);
                color: var(--tx3);
                cursor: not-allowed;
                box-shadow: none;
                transform: none
            }

        .dial-actions {
            display: flex;
            align-items: center;
            gap: 10px
        }

            .dial-actions .btn-call {
                flex: 1
            }

        .btn-del {
            width: 52px;
            height: 52px;
            flex-shrink: 0;
            background: var(--ink3);
            border: 1px solid var(--line);
            border-radius: 50%;
            color: var(--tx2);
            cursor: pointer;
            display: none;
            align-items: center;
            justify-content: center;
            transition: all .2s
        }

            .btn-del.visible {
                display: flex
            }

            .btn-del:hover {
                background: var(--ro3);
                border-color: rgba(255,77,109,.3);
                color: var(--rose);
                transform: scale(1.05)
            }
        /* Recents */
        .ri {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,.04)
        }

        .ricon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            flex-shrink: 0
        }

            .ricon.in {
                background: var(--mi3);
                color: var(--mint)
            }

            .ricon.out {
                background: var(--sk3);
                color: var(--sky)
            }

            .ricon.miss {
                background: var(--ro3);
                color: var(--rose)
            }
        /* ── QUEUE ─────────────────────────────────────────────── */
        .qs-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 6px;
            margin-bottom: 14px
        }

        .qs-card {
            background: var(--ink3);
            border: 1px solid var(--line);
            border-radius: var(--rs);
            padding: 10px 8px;
            text-align: center
        }

        .qs-val {
            font-size: 24px;
            font-weight: 700;
            font-family: var(--mono);
            line-height: 1
        }

        .qs-lbl {
            font-size: 9px;
            color: var(--tx3);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-top: 3px
        }

        .qi {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 9px 10px;
            border-radius: var(--rs);
            border: 1px solid var(--line);
            margin-bottom: 5px;
            background: var(--ink3);
            cursor: pointer;
            transition: border-color .15s
        }

            .qi:hover {
                border-color: var(--violet)
            }

            .qi.hot {
                border-color: rgba(255,77,109,.3);
                background: rgba(255,77,109,.03)
            }

        .qi-pos {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--ink4);
            border: 1px solid var(--line2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            font-family: var(--mono);
            color: var(--tx2);
            flex-shrink: 0
        }

            .qi-pos.r1 {
                background: var(--ro3);
                border-color: rgba(255,77,109,.35);
                color: var(--rose)
            }

            .qi-pos.r2 {
                background: var(--am3);
                border-color: rgba(255,181,71,.3);
                color: var(--amber)
            }

        .qi-info {
            flex: 1;
            min-width: 0
        }

        .qi-name {
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .qi-sub {
            font-size: 10px;
            color: var(--tx3);
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 6px
        }

        .qi-wait {
            font-family: var(--mono);
            font-size: 10px;
            font-weight: 700;
            color: var(--amber);
            background: var(--am3);
            border-radius: 4px;
            padding: 1px 5px
        }

            .qi-wait.hot {
                color: var(--rose);
                background: var(--ro3)
            }

        .btn-take {
            background: var(--vi3);
            border: 1px solid rgba(123,97,255,.25);
            color: var(--violet);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 10px;
            font-weight: 700;
            font-family: var(--font);
            cursor: pointer;
            transition: all .15s;
            white-space: nowrap
        }

            .btn-take:hover {
                background: rgba(123,97,255,.22)
            }
        /* ── AGENTS ─────────────────────────────────────────────── */
        .ai {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 10px;
            border-radius: var(--rs);
            border: 1px solid var(--line);
            margin-bottom: 5px;
            background: var(--ink3)
        }

        .aav {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
            border: 2px solid transparent;
            position: relative
        }

            .aav.on {
                border-color: var(--mint);
                box-shadow: 0 0 10px rgba(0,212,170,.2)
            }

            .aav.busy {
                border-color: var(--rose);
                box-shadow: 0 0 10px rgba(255,77,109,.18)
            }

            .aav.pause {
                border-color: var(--amber);
                box-shadow: 0 0 8px rgba(255,181,71,.18)
            }

            .aav.off {
                border-color: var(--line2);
                opacity: .45
            }

            .aav .live-dot {
                position: absolute;
                bottom: 0;
                right: 0;
                width: 9px;
                height: 9px;
                border-radius: 50%;
                border: 2px solid var(--ink3)
            }

                .aav .live-dot.on {
                    background: var(--mint);
                    animation: lpulse 2s ease-in-out infinite
                }

                .aav .live-dot.busy {
                    background: var(--rose)
                }

                .aav .live-dot.pause {
                    background: var(--amber)
                }

                .aav .live-dot.off {
                    background: var(--tx3)
                }

        @keyframes lpulse {
            0%,100% {
                box-shadow: 0 0 0 0 rgba(0,212,170,.5)
            }

            50% {
                box-shadow: 0 0 0 3px rgba(0,212,170,0)
            }
        }

        .ainfo {
            flex: 1;
            min-width: 0
        }

        .aname {
            font-size: 12px;
            font-weight: 600
        }

        .asub {
            font-size: 10px;
            color: var(--tx3);
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap
        }

        .aext {
            font-family: var(--mono);
            font-size: 10px;
            font-weight: 700;
            color: var(--sky);
            background: var(--sk3);
            border-radius: 4px;
            padding: 1px 6px
        }

        .ast {
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em
        }

            .ast.on {
                color: var(--mint)
            }

            .ast.busy {
                color: var(--rose)
            }

            .ast.pause {
                color: var(--amber)
            }

            .ast.off {
                color: var(--tx3)
            }

        .atimer {
            font-family: var(--mono);
            font-size: 10px;
            color: var(--tx2);
            font-weight: 600
        }

        .acall-num {
            font-size: 10px;
            color: var(--tx3);
            margin-top: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .sup-btns {
            display: flex;
            flex-direction: column;
            gap: 3px
        }

        .btn-sup {
            background: var(--ink4);
            border: 1px solid var(--line2);
            color: var(--tx2);
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 10px;
            font-weight: 700;
            font-family: var(--font);
            cursor: pointer;
            transition: all .15s;
            white-space: nowrap
        }

            .btn-sup.listen:hover {
                background: var(--sk3);
                border-color: rgba(56,182,255,.3);
                color: var(--sky)
            }

            .btn-sup.whisper:hover {
                background: var(--vi3);
                border-color: rgba(123,97,255,.3);
                color: var(--violet)
            }

            .btn-sup.barge:hover {
                background: var(--ro3);
                border-color: rgba(255,77,109,.3);
                color: var(--rose)
            }
        /* Agent xfer (in-call) */
        .axfer-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid rgba(255,255,255,.04)
        }
        /* ── IN-CALL ─────────────────────────────────────────────── */
        #view-calling .hdr {
            background: linear-gradient(135deg,#0e0e1c,#12121f)
        }

        .ct {
            padding: 22px 16px 16px;
            text-align: center;
            background: linear-gradient(180deg,#0d0d1f 0%,var(--ink2) 100%);
            position: relative;
            overflow: hidden
        }

            .ct::before {
                content: '';
                position: absolute;
                top: -60px;
                left: 50%;
                transform: translateX(-50%);
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(123,97,255,.14) 0%,transparent 70%);
                pointer-events: none
            }

        .cav {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            margin: 0 auto 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 23px;
