<script>
// ================================================================
//  VoxFlow — Twilio WebRTC + Temps réel (version propre)
//  Un seul script, zéro conflit
// ================================================================
;(function vfPatch() {

  function waitReady(cb) {
    if (window.S && typeof window.callNum === 'function') cb()
    else setTimeout(function() { waitReady(cb) }, 300)
  }

  waitReady(function() {
    var S = window.S
    window.__VFDevice = null
    window.__VFCall   = null

    // ── Init Twilio Device ──────────────────────────────────────
    function initTwilio() {
      if (window.__VFDevice) return
      var tok = S.tok || localStorage.getItem('vf_tok')
      var url = S.url || localStorage.getItem('vf_url') || 'http://localhost:4000'
      if (!tok || typeof Twilio === 'undefined') {
        setTimeout(initTwilio, 1000)
        return
      }

      fetch(url + '/api/v1/telephony/voice/token', {
        headers: { Authorization: 'Bearer ' + tok }
      })
      .then(function(r) { return r.json() })
      .then(function(data) {
        if (!data.success || !data.data || !data.data.token) {
          console.warn('[VF] Token WebRTC non disponible')
          return
        }

        var dev = new Twilio.Device(data.data.token, {
          logLevel: 1,
          codecPreferences: ['opus', 'pcmu'],
          enableRingingState: true,
        })

        dev.on('registered', function() {
          window.__VFDevice = dev
          console.log('[VF] Twilio Device enregistre ✓')
        })

        dev.on('error', function(e) {
          console.warn('[VF] Twilio error:', e.message)
          window.__VFDevice = null
          setTimeout(initTwilio, 5000)
        })

        dev.on('incoming', function(call) {
          window.__VFCall = call
          var from = call.parameters.From || 'Inconnu'
          S._inNum = from
          S._inCo  = null

          // Lookup contact
          var t = S.tok || localStorage.getItem('vf_tok')
          var u = S.url || localStorage.getItem('vf_url') || 'http://localhost:4000'
          if (t) {
            fetch(u + '/api/v1/telephony/lookup/' + encodeURIComponent(from), {
              headers: { Authorization: 'Bearer ' + t }
            })
            .then(function(r) { return r.json() })
            .then(function(d) {
              if (d.success && d.data && d.data.contact) {
                S._inCo = d.data.contact
                var n = document.getElementById('inc-name')
                var c = document.getElementById('inc-co')
                if (n) n.textContent = d.data.contact.first_name + ' ' + d.data.contact.last_name
                if (c) c.textContent = d.data.contact.company || ''
              }
            })
            .catch(function() {})
          }

          var ne = document.getElementById('inc-num')
          var nm = document.getElementById('inc-name')
          if (ne) ne.textContent = from
          if (nm && nm.textContent === 'Inconnu') nm.textContent = from
          if (typeof showView === 'function') showView('incoming')

          call.on('cancel', function() {
            window.__VFCall = null
            if (typeof showView === 'function') showView('main')
            refreshData()
          })
        })

        dev.register()
      })
      .catch(function(e) {
        console.warn('[VF] initTwilio failed:', e.message)
      })
    }

    // ── Refresh données ─────────────────────────────────────────
    function refreshData() {
      var tok = S.tok || localStorage.getItem('vf_tok')
      var url = S.url || localStorage.getItem('vf_url') || 'http://localhost:4000'
      if (!tok) return

      var h = { Authorization: 'Bearer ' + tok }

      Promise.all([
        fetch(url + '/api/v1/telephony/calls?limit=30',  { headers: h }).then(function(r) { return r.json() }).catch(function() { return {success:false} }),
        fetch(url + '/api/v1/telephony/voicemails',       { headers: h }).then(function(r) { return r.json() }).catch(function() { return {success:false} }),
        fetch(url + '/api/v1/queues',              { headers: h }).then(function(r) { return r.json() }).catch(function() { return {success:false} }),
        fetch(url + '/api/v1/supervision/snapshot',         { headers: h }).then(function(r) { return r.json() }).catch(function() { return {success:false} }),
      ]).then(function(res) {
        if (res[0].success && res[0].data) { S.calls  = res[0].data; if (typeof rRecents==='function') rRecents(); if (typeof rHistory==='function') rHistory() }
        if (res[1].success && res[1].data) { S.vms    = res[1].data; if (typeof rVMs==='function') rVMs() }
        if (res[2].success && res[2].data) { S.queue  = res[2].data; if (typeof rQueue==='function') rQueue() }
        if (res[3].success && res[3].data) { S.agents = res[3].data; if (typeof rAgents==='function') rAgents() }
      })
    }
    window.__vfRefresh = refreshData

    // ── Poll 5s ─────────────────────────────────────────────────
    if (window.__vfPoll) clearInterval(window.__vfPoll)
    window.__vfPoll = setInterval(function() {
      if (S.tok || localStorage.getItem('vf_tok')) refreshData()
    }, 15000)

    // ── Patch hangup ────────────────────────────────────────────
    var _origHangup = window.hangup
    window.hangup = async function() {
      // 1. Couper Twilio Device WebRTC
      if (window.__VFCall) {
        try { window.__VFCall.disconnect() } catch(e) {}
        window.__VFCall = null
      }
      // 2. Couper via API REST (termine l'appel côté Twilio)
      var tok = S.tok || localStorage.getItem('vf_tok')
      var url = S.url || localStorage.getItem('vf_url') || 'http://localhost:4000'
      if (S.callId && tok) {
        fetch(url + '/api/v1/telephony/call/' + S.callId + '/end', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + tok },
          body: JSON.stringify({ duration: S.tsec || 0, twilioSid: S.twSid || '' })
        }).catch(function() {})
      }
      // 3. Appeler hangup original
      if (_origHangup) await _origHangup()
      // 4. Refresh après 1.5s
      setTimeout(refreshData, 1500)
      setTimeout(refreshData, 4000)
    }

    // ── Patch doAnswer ──────────────────────────────────────────
    var _origAnswer = window.doAnswer
    window.doAnswer = function() {
      if (window.__VFCall) {
        window.__VFCall.accept()
        window.__VFCall.on('disconnect', function() {
          window.__VFCall = null
          if (typeof hangup === 'function') hangup()
        })
      }
      if (_origAnswer) _origAnswer()
    }

    // ── Patch doMute ────────────────────────────────────────────
    var _origMute = window.doMute
    window.doMute = function() {
      if (window.__VFCall) window.__VFCall.mute(!S.muted)
      if (_origMute) _origMute()
    }

    // ── Patch callNum ───────────────────────────────────────────
    var _origCallNum = window.callNum
    window.callNum = async function(n) {
      var to  = n || (document.getElementById('dinp') ? document.getElementById('dinp').value.trim() : '')
      if (!to) return
      var tok = S.tok || localStorage.getItem('vf_tok')
      var url = S.url || localStorage.getItem('vf_url') || 'http://localhost:4000'

      if (window.__VFDevice && tok) {
        // ── Via Twilio Device WebRTC ──────────────────────────
        try {
          // Enregistrer en DB
          var dbRes  = await fetch(url + '/api/v1/telephony/call/outbound', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + tok },
            body: JSON.stringify({ to: to })
          })
          var dbData = await dbRes.json()
          if (dbData.success && dbData.data) {
            S.callId  = dbData.data.call ? dbData.data.call.id   : null
            S.twSid   = dbData.data.call ? dbData.data.call.twilio_sid : null
            S.contact = dbData.data.contact || null
          }

          // Lancer l'appel WebRTC
          var call = await window.__VFDevice.connect({ params: { To: to } })
          window.__VFCall = call

          // Recuperer le CallSid des que possible
          call.on('ringing', function() { console.log('[VF] Sonnerie...') })
          call.on('accept',  function(c) {
            if (c && c.parameters && c.parameters.CallSid) {
              S.twSid = c.parameters.CallSid
              // Mettre a jour en DB
              if (S.callId) {
                fetch(url + '/api/v1/telephony/call/' + S.callId + '/notes', {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + tok },
                  body: JSON.stringify({ twilioSid: S.twSid })
                }).catch(function() {})
              }
            }
          })
          call.on('disconnect', function() {
            window.__VFCall = null
            if (typeof hangup === 'function') hangup()
          })
          call.on('error', function(e) {
            console.error('[VF] Appel error:', e.message)
            window.__VFCall = null
            if (typeof showView === 'function') showView('main')
          })

          // Afficher ecran appel
          S.dir = 'OUTBOUND'
          if (typeof startCall === 'function') startCall(to)

        } catch(e) {
          console.error('[VF] Device.connect() failed:', e.message)
          alert('Erreur Twilio: ' + e.message)
        }

      } else {
        // ── Fallback API REST ─────────────────────────────────
        console.warn('[VF] Device non pret — fallback REST')
        if (_origCallNum) await _origCallNum(n)
      }
    }

    // ── Patch doLogin — re-init Twilio apres connexion ──────────
    var _origLogin = window.doLogin
    window.doLogin = async function() {
      if (_origLogin) await _origLogin()
      setTimeout(function() {
        window.__VFDevice = null
        initTwilio()
        refreshData()
      }, 1000)
    }

    // ── Demarrer si deja connecte ────────────────────────────────
    var tok = S.tok || localStorage.getItem('vf_tok')
    if (tok) {
      S.tok = tok
      S.url = localStorage.getItem('vf_url') || S.url
      initTwilio()
      refreshData()
    }

    // Storage sync (connexion depuis portail)
    window.addEventListener('storage', function(e) {
      if (e.key === 'vf_tok') {
        if (e.newValue) {
          S.tok = e.newValue
          S.url = localStorage.getItem('vf_url') || S.url
          window.__VFDevice = null
          initTwilio()
          refreshData()
          if (typeof showView === 'function') showView('main')
          if (typeof startPoll === 'function') startPoll()
        } else {
          S.tok = null
          if (window.__VFDevice) { try { window.__VFDevice.destroy() } catch(e2) {} window.__VFDevice = null }
          if (typeof stopPoll === 'function') stopPoll()
          if (typeof showView === 'function') showView('login')
        }
      }
    })

    console.log('[VF] Patch charge ✓')
  })

})()
