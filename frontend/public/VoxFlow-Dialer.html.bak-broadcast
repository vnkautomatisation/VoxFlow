// ── VoxFlow Auth sync ────────────────────────────────────────────
// postMessage depuis le portail
window.addEventListener('message', function(e) {
  try {
    if (!e.data || !e.data.type) return
    if (e.data.type === 'VOXFLOW_LOGOUT') {
      localStorage.removeItem('vf_tok')
      if (window.S) window.S.tok = null
      if (typeof stopPoll === 'function') stopPoll()
      if (typeof showView === 'function') showView('login')
    }
    if (e.data.type === 'VOXFLOW_TOKEN' && e.data.tok) {
      localStorage.setItem('vf_tok', e.data.tok)
      if (e.data.url) localStorage.setItem('vf_url', e.data.url)
      if (window.S) { window.S.tok = e.data.tok; if (e.data.url) window.S.url = e.data.url }
    }
  } catch(err) {}
})
// Storage events (même domaine = même localStorage)
window.addEventListener('storage', function(e) {
  if (e.key !== 'vf_tok') return
  if (!e.newValue) {
    if (window.S) window.S.tok = null
    if (typeof stopPoll === 'function') stopPoll()
    if (typeof showView === 'function') showView('login')
  } else {
    if (window.S) { window.S.tok = e.newValue; window.S.url = localStorage.getItem('vf_url') || window.S.url }
    if (typeof loadData === 'function') loadData()
    if (typeof startPoll === 'function') startPoll()
    if (typeof showView === 'function') showView('main')
  }
})
</script>
