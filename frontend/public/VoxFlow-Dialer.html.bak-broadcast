            role: localStorage.getItem('vf_role') || 'AGENT',  // OWNER | ADMIN | AGENT
            ext: '201',
            status: 'ONLINE',
            calls: [], vms: [], agents: [], queue: [],
            callId: null, twSid: null, contact: null, dir: 'OUTBOUND',
            muted: false, hold: false, rec: false,
            tsec: 0, tint: null, panel: null, xt: 'blind',
            hf: 'all', poll: null,
            _inCo: null, _inNum: null,
        }

        // Helpers de permission
        const isAdmin = () => S.role === 'ADMIN' || S.role === 'OWNER'
        const isOwner = () => S.role === 'OWNER'

        // ════════════════════════════════════════════════════════════
        //  API
        // ════════════════════════════════════════════════════════════
        const api = async (p, o = {}) => {
            const r = await fetch(S.url + p, {
                ...o,
                headers: {
                    'Content-Type': 'application/json',
                    ...(S.tok ? { Authorization: 'Bearer ' + S.tok } : {}),
                    ...(o.headers || {}),
                },
                body: o.body ? JSON.stringify(o.body) : undefined,
            })
            return r.json()
        }

        const showView = id => {
            document.querySelectorAll('.view').forEach(v => v.classList.remove('on'))
            document.getElementById('view-' + id).classList.add('on')
        }

        const toast = (msg, d = 2500) => {
            const e = document.getElementById('toast')
            e.textContent = msg; e.classList.add('on')
            setTimeout(() => e.classList.remove('on'), d)
        }

        // ════════════════════════════════════════════════════════════
        //  PERMISSIONS — appliquer restrictions de rôle
        // ════════════════════════════════════════════════════════════
        function applyRolePermissions() {
            const admin = isAdmin()

            // Badge rôle dans le header
            const badge = document.getElementById('role-badge')
            if (badge) {
                badge.textContent = S.role === 'OWNER' ? 'Owner' : S.role === 'ADMIN' ? 'Admin' : 'Agent'
                badge.className = 'role-badge ' + (admin ? 'admin' : 'agent')
            }

            // Onglet Agents — Admin seulement
            document.querySelectorAll('.admin-only').forEach(el => {
                el.style.display = admin ? '' : 'none'
            })

            // Bouton Enregistrement — Admin seulement
            const recBtn = document.getElementById('btn-rec-btn')
            if (recBtn) {
                if (!admin) {
                    recBtn.classList.add('locked')
                    recBtn.onclick = () => toast('🔒 Réservé aux administrateurs')
                }
            }

            // Transfert vers agents — Admin seulement dans le panel
            // (le champ numéro reste pour agents, la liste agents est admin only)
            const xferAgentSec = document.getElementById('xfer-agents-section')
            if (xferAgentSec) {
                xferAgentSec.style.display = 'none' // géré dans setXT
            }

            // Historique — Agent voit seulement ses appels (filtré côté API déjà)
            // Supervision dans onglet Agents — géré dans rAgents()
        }

        // ════════════════════════════════════════════════════════════
        //  INIT
        // ════════════════════════════════════════════════════════════
        async function init() {
            document.getElementById('inp-url').value = S.url
            document.getElementById('btn-login').onclick = doLogin
            document.getElementById('inp-pass').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin() })
            document.getElementById('btn-answer').onclick = doAnswer
            document.getElementById('btn-refuse').onclick = hangup
            updDot()
            // Auth depuis URL params (portail → dialer)
    try {
      var _p = new URLSearchParams(window.location.search)
      var _tok = _p.get('tok'), _url = _p.get('url')
      if (_tok) { localStorage.setItem('vf_tok', _tok); S.tok = _tok }
      if (_url) { localStorage.setItem('vf_url', _url); S.url = _url }
    } catch(e) {}

    // Si connecté → charger vraies données, sinon → login
    var _savedTok = S.tok || localStorage.getItem('vf_tok')
    var _savedRole = localStorage.getItem('vf_role')
    if (_savedTok) {
      S.tok  = _savedTok
      S.url  = localStorage.getItem('vf_url') || S.url
      S.role = _savedRole || S.role
      applyRolePermissions()
      showView('main')
      loadData()
      startPoll()
    } else {
      showView('login')
    }
        }

        // ════════════════════════════════════════════════════════════
        //  AUTH
        // ════════════════════════════════════════════════════════════
        async function doLogin() {
            const url = document.getElementById('inp-url').value.trim().replace(/\/$/, '')
            const email = document.getElementById('inp-email').value.trim()
            const pass = document.getElementById('inp-pass').value
            S.url = url; localStorage.setItem('vf_url', url)

            const btn = document.getElementById('btn-login')
            btn.textContent = 'Connexion...'; btn.disabled = true

            const r = await api('/api/v1/auth/login', { method: 'POST', body: { email, password: pass } })

            if (r.success && r.data?.accessToken) {
                S.tok = r.data.accessToken
                S.role = r.data.user?.role || 'AGENT'
                localStorage.setItem('vf_tok', S.tok)
                localStorage.setItem('vf_role', S.role)
                applyRolePermissions()
                showView('main')
                await loadData()
                startPoll()
            } else {
                showErr(r.message || 'Identifiants incorrects')
                btn.textContent = 'Se connecter'; btn.disabled = false
            }
        }

        function showErr(m) {
            const e = document.getElementById('lerr')
            e.textContent = m; e.style.display = 'block'
            setTimeout(() => e.style.display = 'none', 4000)
        }

        function doLogout() {
            localStorage.removeItem('vf_tok')
            localStorage.removeItem('vf_role')
            S.tok = null; stopPoll(); showView('login')
        }

        // ════════════════════════════════════════════════════════════
        //  DATA
        // ════════════════════════════════════════════════════════════
        async function loadData() {
            try {
                const [cr, vr] = await Promise.all([
                    api('/api/v1/telephony/calls?limit=30'),
                    api('/api/v1/telephony/voicemails'),
                ])
                if (cr.success) { S.calls = cr.data || []; rRecents(); rHistory() }
                if (vr.success) { S.vms = vr.data || []; rVMs() }
            } catch { }
            try {
                const [qr, ar] = await Promise.all([
                    api('/api/v1/queues'),
                    api('/api/v1/supervision/snapshot'),
                ])
                if (qr.success) { S.queue = qr.data || []; rQueue() }
                if (ar.success && ar.data) { S.agents = (ar.data.agentStatuses||ar.data.agents||ar.data||[]).map(function(a){return{id:a.agentId||a.id,first_name:a.name?a.name.split(' ')[0]:'Agent',last_name:a.name?a.name.split(' ').slice(1).join(' '):'',status:a.status||'OFFLINE',extension:a.extension||'',current_call:!!(a.callId),current_call_number:a.callFrom||a.callTo||null,call_duration:a.callDuration||0}}); rAgents() }
            } catch { }
        }

        function startPoll() { S.poll = setInterval(async () => { try { const qr = await api('/api/v1/queues'); if (qr.success) { S.queue = qr.data || []; rQueue() } const ar = await api('/api/v1/supervision/snapshot'); if (ar.success && ar.data) { S.agents = (ar.data.agentStatuses||ar.data.agents||ar.data||[]).map(function(a){return{id:a.agentId||a.id,first_name:a.name?a.name.split(' ')[0]:'Agent',last_name:a.name?a.name.split(' ').slice(1).join(' '):'',status:a.status||'OFFLINE',extension:a.extension||'',current_call:!!(a.callId),current_call_number:a.callFrom||a.callTo||null,call_duration:a.callDuration||0}}); rAgents() } } catch { } }, 15000) }
        function stopPoll() { clearInterval(S.poll) }

        // ════════════════════════════════════════════════════════════
        //  TABS
        // ════════════════════════════════════════════════════════════
        const PANES = ['dialer', 'queue', 'agents', 'history', 'voicemails', 'search']
        function goTab(id, btn) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'))
            btn.classList.add('on')
            PANES.forEach(p => { const el = document.getElementById('pane-' + p); if (el) el.classList.toggle('on', p === id) })
        }

        // ════════════════════════════════════════════════════════════
        //  STATUS
        // ════════════════════════════════════════════════════════════
        function doStatus(s) {
            S.status = s; updDot()
            api('/api/v1/telephony/status', { method: 'PATCH', body: { status: s } }).catch(() => { })
        }
        function updDot() {
            const d = document.getElementById('sdot'); if (!d) return
            const c = { ONLINE: 'var(--mint)', BREAK: 'var(--amber)', OFFLINE: 'var(--tx3)' }
            const g = { ONLINE: '0 0 6px var(--mint)', BREAK: '0 0 6px var(--amber)', OFFLINE: 'none' }
            d.style.background = c[S.status] || c.OFFLINE
            d.style.boxShadow = g[S.status] || g.OFFLINE
            d.className = 'chip-dot ' + (S.status === 'ONLINE' ? 'on' : S.status === 'BREAK' ? 'pause' : 'off')
        }

        // ════════════════════════════════════════════════════════════
        //  DIALER
        // ════════════════════════════════════════════════════════════
        function ak(k) { const i = document.getElementById('dinp'); i.value += k; onDial() }
        function dk() { const i = document.getElementById('dinp'); i.value = i.value.slice(0, -1); onDial() }

        let _lpt = null, _lpdone = false
        function startLong(e) {
            if (e) e.preventDefault(); _lpdone = false
            _lpt = setTimeout(() => {
                _lpdone = true
                const i = document.getElementById('dinp')
                if (i.value.endsWith('0')) i.value = i.value.slice(0, -1)
                ak('+')
                const btn = document.getElementById('key-zero')
                if (btn) { btn.style.background = 'var(--vi3)'; btn.style.color = 'var(--violet)'; setTimeout(() => { btn.style.background = ''; btn.style.color = '' }, 300) }
            }, 500)
        }
        function endLong() { if (_lpt) { clearTimeout(_lpt); _lpt = null } }

        function onDial() {
            const v = document.getElementById('dinp').value.trim()
            document.getElementById('btn-call').disabled = !v
            document.getElementById('btn-del')?.classList.toggle('visible', v.length > 0)
        }

        async function callNum(n) {
            const to = n || document.getElementById('dinp')?.value.trim(); if (!to) return
            try {
                const r = await api('/api/v1/telephony/call/outbound', { method: 'POST', body: { to } })
                if (r.success) { S.callId = r.data.call?.id || null; S.twSid = r.data.call?.twilio_sid || null; S.contact = r.data.contact || null; S.dir = 'OUTBOUND'; startCall(to) }
                else alert(r.message || 'Erreur appel')
            } catch { alert('Erreur réseau') }
        }

        // ════════════════════════════════════════════════════════════
        //  START CALL
        // ════════════════════════════════════════════════════════════
        const ACP = [['#2d1a80', '#3d1fa3'], ['#1a356b', '#1a4d8f'], ['#1a4d3a', '#1a6b54'], ['#4d1a5a', '#6b1a80'], ['#4d2a1a', '#6b3a1a'], ['#1a3a4d', '#1a5270'], ['#3a4d1a', '#506b1a']]

        function startCall(num) {
            S.muted = false; S.hold = false; S.rec = false; S.tsec = 0; S.panel = null
            const c = S.contact
            const ini = c ? ((c.first_name || '')[0] + (c.last_name || '')[0]).toUpperCase() : (num[0] || '?').toUpperCase()
            const pi = ini.charCodeAt(0) % ACP.length
            const [c1, c2] = ACP[pi]

            const av = document.getElementById('call-av')
            av.style.background = `linear-gradient(135deg,${c1},${c2})`
            document.getElementById('call-init').textContent = ini
            document.getElementById('call-name').textContent = c ? c.first_name + ' ' + c.last_name : num
            document.getElementById('call-co').textContent = c?.company || ''
            document.getElementById('call-num').textContent = c ? num : ''
            document.getElementById('call-timer').textContent = '00:00'
            document.getElementById('call-ext').textContent = 'EXT ' + S.ext
            document.getElementById('call-dir-lbl').querySelector('span').textContent = S.dir === 'INBOUND' ? 'Entrant' : 'Sortant'

            // Insights
            const ins = document.getElementById('ins-box')
            if (c) {
                ins.style.display = 'block'
                document.getElementById('ins-rows').innerHTML = [
                    c.email ? ir('Email', c.email) : '',
                    c.phone ? ir('Téléphone', c.phone) : '',
                    c.company ? ir('Entreprise', c.company) : '',
                    c.pipeline_stage ? ir('Pipeline', c.pipeline_stage, 'vi') : '',
                    c.total_calls ? ir('Appels totaux', c.total_calls + ' appels', 'mi') : '',
                    c.last_call ? ir('Dernier appel', fmtD(c.last_call)) : '',
                    c.tags?.length ? ir('Tags', c.tags.slice(0, 2).join(', ')) : '',
                ].filter(Boolean).join('')
            } else ins.style.display = 'none'

            // Reset
            document.querySelectorAll('.abt:not(.locked)').forEach(b => b.className = 'abt')
            document.querySelectorAll('.cpanel').forEach(p => p.classList.remove('on'))
            const pill = document.getElementById('call-pill'); pill.textContent = 'En communication'; pill.className = 'cpill'
            document.getElementById('rec-badge').style.display = 'none'
            document.getElementById('rec-ind').classList.remove('on')

            showView('calling')
            clearInterval(S.tint)
            S.tint = setInterval(() => { S.tsec++; const el = document.getElementById('call-timer'); if (el) el.textContent = fmtT(S.tsec) }, 1000)
        }

        function ir(l, v, cls = '') { return `<div class="ins-row"><span>${l}</span><span class="ins-val ${cls}">${v}</span></div>` }

        async function hangup() {
            clearInterval(S.tint); const dur = S.tsec
            if (S.callId) { const n = document.getElementById('notes-inp')?.value || ''; await api('/api/v1/telephony/call/' + S.callId + '/end', { method: 'PATCH', body: { duration: dur, notes: n } }).catch(() => { }) }
            document.getElementById('wu-dur').textContent = 'Durée : ' + fmtT(dur)
            document.querySelectorAll('#stars span').forEach(s => s.style.color = 'var(--tx3)')
            showView('wrapup')
            setTimeout(async () => {
                S.callId = null; S.contact = null; S.twSid = null
                const di = document.getElementById('dinp'); const ni = document.getElementById('notes-inp')
                if (di) { di.value = ''; onDial() }; if (ni) ni.value = ''
                showView('main'); await loadData()
            }, 3200)
        }

        // ════════════════════════════════════════════════════════════
        //  CALL ACTIONS
        // ════════════════════════════════════════════════════════════
        function doMute() {
            S.muted = !S.muted
            document.getElementById('btn-mute').className = 'abt' + (S.muted ? ' m-mute' : '')
            updPill()
            if (S.callId) api('/api/v1/telephony/call/' + S.callId + '/mute', { method: 'PATCH', body: { mute: S.muted } }).catch(() => { })
            toast(S.muted ? '🔇 Micro coupé' : '🎙️ Micro actif')
        }
        function doHold() {
            S.hold = !S.hold
            document.getElementById('btn-hold').className = 'abt' + (S.hold ? ' m-hold' : '')
            updPill()
            if (S.callId) api('/api/v1/telephony/call/' + S.callId + '/hold', { method: 'PATCH', body: { hold: S.hold } }).catch(() => { })
            toast(S.hold ? '⏸ Appel en attente' : '▶ Appel repris')
        }
        function doRec() {
            if (!isAdmin()) { toast('🔒 Réservé aux administrateurs'); return }
            S.rec = !S.rec
            document.getElementById('btn-rec-btn').className = 'abt' + (S.rec ? ' m-rec' : '')
            document.getElementById('rec-badge').style.display = S.rec ? 'flex' : 'none'
            document.getElementById('rec-ind').classList.toggle('on', S.rec)
            toast(S.rec ? '⏺ Enregistrement démarré' : '⏹ Enregistrement arrêté')
        }
        function updPill() {
            const p = document.getElementById('call-pill')
            if (S.hold) { p.textContent = '⏸ En attente'; p.className = 'cpill hold' }
            else if (S.muted) { p.textContent = '🔇 Micro coupé'; p.className = 'cpill muted' }
            else { p.textContent = 'En communication'; p.className = 'cpill' }
        }

        let _xt = 'blind'
        function setXT(t, b) {
            _xt = t
            document.querySelectorAll('#cpanel-xfer .fc').forEach(x => x.classList.remove('on'))
            b.classList.add('on')

            // Agents dispo — Admin seulement
            const sec = document.getElementById('xfer-agents-section')
            const list = document.getElementById('xfer-agents-list')
            if ((t === 'attended' || t === 'conf') && isAdmin()) {
                sec.style.display = 'block'
                const avail = S.agents.filter(a => a.status === 'ONLINE' && !a.current_call)
                if (!avail.length) {
                    list.innerHTML = '<div style="font-size:11px;color:var(--tx3);padding:6px 0">Aucun agent disponible</div>'
                } else {
                    list.innerHTML = avail.map(a => {
                        const name = a.first_name + ' ' + a.last_name
                        const ext = a.extension || a.ext || '—'
                        return `<div class="axfer-row">
                  <div><span style="font-size:11px;font-weight:600">${name}</span><span class="aext" style="margin-left:6px">${ext}</span></div>
                  <button class="btn-take" onclick="xferToAgent('${ext}')">→ Transférer</button>
                </div>`
                    }).join('')
                }
            } else {
                sec.style.display = 'none'
            }
        }

        function xferToAgent(ext) { document.getElementById('xfer-inp').value = ext; execTransfer() }

        async function execTransfer() {
            const to = document.getElementById('xfer-inp').value.trim()
            if (!to || !S.callId) return
            await api('/api/v1/telephony/call/' + S.callId + '/transfer', { method: 'POST', body: { to, type: _xt } }).catch(() => { })
            toast('→ Transfert en cours…')
            if (_xt === 'blind') setTimeout(hangup, 900)
        }

        function saveNotes() {
            const n = document.getElementById('notes-inp').value
            if (n && S.callId) { api('/api/v1/telephony/call/' + S.callId + '/notes', { method: 'PATCH', body: { notes: n } }).catch(() => { }); toast('✓ Notes sauvegardées') }
        }
        function dtmf(k) { toast('DTMF: ' + k); console.log('[DTMF]', k) }
        function openCRM() { window.open(S.url.replace(':4000', ':3001') + '/admin/crm', '_blank') }
        function doAnswer() { S.contact = S._inCo || null; S.dir = 'INBOUND'; startCall(S._inNum || 'Entrant') }

        function doPanel(name) {
            const map = { xfer: 'cpanel-xfer', notes: 'cpanel-notes', kpad: 'cpanel-kpad' }
            const btn = { xfer: 'btn-xt', notes: 'btn-notes', kpad: 'btn-kpad' }
            const open = S.panel === name
            Object.values(map).forEach(p => document.getElementById(p).classList.remove('on'))
            Object.values(btn).forEach(b => document.getElementById(b).classList.remove('m-panel'))
            S.panel = open ? null : name
            if (!open) { document.getElementById(map[name]).classList.add('on'); document.getElementById(btn[name]).classList.add('m-panel') }
        }

        function star(n) { document.querySelectorAll('#stars span').forEach((s, i) => s.style.color = i < n ? 'var(--amber)' : 'var(--tx3)'); toast('★ Évaluation enregistrée') }

        // ════════════════════════════════════════════════════════════
        //  QUEUE
        // ════════════════════════════════════════════════════════════
        function rQueue() {
            const waiting = S.queue.filter(q => q.status === 'waiting' || !q.status)
            const active = S.queue.filter(q => q.status === 'active')
            const bdg = document.getElementById('q-bdg'); bdg.textContent = waiting.length; bdg.style.display = waiting.length ? 'flex' : 'none'
            document.getElementById('qs-w').textContent = waiting.length
            document.getElementById('qs-d').textContent = S.queue.filter(q => q.status === 'completed').length || 0
            const avg = waiting.length ? waiting.reduce((a, q) => a + (q.wait_seconds || 0), 0) / waiting.length : 0
            document.getElementById('qs-a').textContent = fmtT(Math.round(avg))

            const ql = document.getElementById('q-list')
            if (!waiting.length) { ql.innerHTML = '<div class="empty">File vide ✓</div>' }
            else ql.innerHTML = waiting.map((q, i) => {
                const w = q.wait_seconds || (i + 1) * 52; const hot = w > 120; const n = q.caller_name || q.from_number || 'Inconnu'
                const pc = i === 0 ? 'r1' : i === 1 ? 'r2' : ''
                return `<div class="qi ${hot ? 'hot' : ''}" onclick="pickQ('${q.from_number || ''}')">
              <div class="qi-pos ${pc}">${i + 1}</div>
              <div class="qi-info"><div class="qi-name">${n}</div><div class="qi-sub"><span>${q.from_number || ''}</span><span class="qi-wait ${hot ? 'hot' : ''}">${fmtT(w)}</span></div></div>
              <button class="btn-take" onclick="event.stopPropagation();pickQ('${q.from_number || ''}')">Prendre</button>
            </div>`
            }).join('')

            const al = document.getElementById('q-active')
            if (!active.length) { al.innerHTML = '<div class="empty">Aucun appel actif</div>' }
            else al.innerHTML = active.map(q => `<div class="qi">
            <div class="qi-pos" style="background:var(--mi3);border-color:rgba(0,212,170,.3);color:var(--mint)">●</div>
            <div class="qi-info"><div class="qi-name">${q.caller_name || q.from_number || 'Inconnu'}</div>
            <div class="qi-sub"><span>${q.agent_name || 'Agent'}</span><span class="qi-wait" style="color:var(--mint);background:var(--mi3)">${fmtT(q.duration || 0)}</span></div></div>
          </div>`).join('')
        }

        function pickQ(num) { if (num) { S.dir = 'INBOUND'; callNum(num) } }

        // ════════════════════════════════════════════════════════════
        //  AGENTS — Supervision ADMIN seulement
        // ════════════════════════════════════════════════════════════
        function rAgents() {
            const el = document.getElementById('ag-list')
            if (!S.agents.length) { el.innerHTML = '<div class="empty">Aucun agent connecté</div>'; return }
            const on = S.agents.filter(a => a.status === 'ONLINE' && !a.current_call).length
            const busy = S.agents.filter(a => a.current_call || a.status === 'BUSY').length
            const pause = S.agents.filter(a => a.status === 'BREAK').length
            document.getElementById('ag-on').textContent = on
            document.getElementById('ag-busy').textContent = busy
            document.getElementById('ag-pause').textContent = pause
            const stL = { online: 'Disponible', busy: 'En appel', break: 'En pause', offline: 'Hors ligne' }

            el.innerHTML = S.agents.map((a, i) => {
                const st = a.current_call ? 'busy' : (a.status || 'ONLINE').toLowerCase()
                const name = a.name || (a.first_name ? a.first_name + ' ' + a.last_name : 'Agent ' + i)
                const ext = a.extension || a.ext || (200 + i + 1)
                const ini = name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase()
                const [bg1, bg2] = ACP[i % ACP.length]
                const dur = a.call_duration || 0

                // Supervision — admin seulement
                const supBtns = (st === 'busy' && isAdmin()) ? `
              <div class="sup-btns">
                <button class="btn-sup listen"  onclick="supListen('${a.id || i}')">👂 Écouter</button>
                <button class="btn-sup whisper" onclick="supWhisper('${a.id || i}')">🗣 Chuchoter</button>
                <button class="btn-sup barge"   onclick="supBarge('${a.id || i}')">⚡ Rejoindre</button>
              </div>` : ''

