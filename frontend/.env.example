# ══════════════════════════════════════════════
#  VoxFlow — Variables frontend (Next.js)
#  Copier ce fichier en .env.local
# ══════════════════════════════════════════════

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VoxFlow
NODE_ENV=development

# Supabase (clés publiques — safe côté client)
# Pour activer le SSO Google/Microsoft :
#   1. Dans Supabase Dashboard → Authentication → Providers
#   2. Activer Google (nécessite Google Cloud Console OAuth Client ID)
#   3. Activer Azure (Microsoft — nécessite Azure AD App registration)
#   4. Ajouter http://localhost:3001/callback dans les Redirect URLs autorisés
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe (clé publique uniquement)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx

# Twilio (Account SID uniquement — pas le token !)
NEXT_PUBLIC_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL du backend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Feature flags
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_SMS=true
NEXT_PUBLIC_ENABLE_CHAT=false
