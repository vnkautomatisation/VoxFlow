{
  "name": "voxflow-dialer",
  "version": "1.2.5",
  "description": "VoxFlow Dialer — Minimal Electron shell loading the Next.js dialer page. By VNK Automatisation Inc.",
  "main": "main.js",
  "author": "VNK Automatisation Inc.",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev":   "electron .",
    "build": "electron-builder --win --publish never"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "io.voxflow.dialer",
    "productName": "VoxFlow Dialer",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "src/**/*",
      "!src/index.html.bak",
      "!*.bak*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [ "x64" ]
        }
      ],
      "icon": "src/icon.ico",
      "sign": null,
      "signingHashAlgorithms": null,
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VoxFlow Dialer",
      "runAfterFinish": true
    }
  }
}