{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*":           ["./src/*"],
      "@routes/*":     ["./src/routes/*"],
      "@services/*":   ["./src/services/*"],
      "@middleware/*": ["./src/middleware/*"],
      "@models/*":     ["./src/models/*"],
      "@utils/*":      ["./src/utils/*"],
      "@config/*":     ["./src/config/*"],
      "@types/*":      ["./src/types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
