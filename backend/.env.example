# ══════════════════════════════════════════════
#  VoxFlow — Variables backend (Node.js)
#  Copier ce fichier en .env
# ══════════════════════════════════════════════

# App
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Base de données
DATABASE_URL=postgresql://postgres:voxflow_dev_password@localhost:5432/voxflow
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Auth JWT
JWT_SECRET=change_this_to_a_random_64_char_hex_string
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change_this_to_another_random_64_char_hex

# Redis
REDIS_URL=redis://localhost:6379
# Production Upstash : rediss://default:xxxx@your-upstash-url:6380

# ── Twilio (GARDER SECRET — serveur uniquement) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret_here
TWILIO_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxx

# ── OpenAI ──────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ── Email (Resend) ───────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@voxflow.io
EMAIL_FROM_NAME=VoxFlow

# ── Stockage enregistrements ─────────────────────
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=recordings

# ── Monitoring ───────────────────────────────────
SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx

# ── CORS ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
